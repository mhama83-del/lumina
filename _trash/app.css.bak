/* ============================================================
   LUMINA — Design System (Fasa 0)
   Navy editorial theme matching the demo deck.
   ============================================================ */

:root{
  /* Background */
  --bg:        #0B1220;
  --bg-blob:   #15203A;
  --card:      #111A2E;
  --card-2:    #0F1A30;
  --border:    #2A3552;

  /* Text */
  --text:      #F5F7FA;
  --muted:     #9AA4B8;

  /* Accents (pillar colours) */
  --gold:      #F5C518;
  --indigo:    #6D5DFB;
  --green:     #2E9E5B;
  --teal:      #14B8A6;
  --violet:    #8B7CF0;

  /* Status (colour-blind safe) */
  --ok:        #2E9E5B;
  --nudge:     #E0A82E;
  --risk:      #E0526B;

  /* Shape */
  --radius:    16px;
  --radius-sm: 10px;
  --shadow:    0 10px 30px rgba(0,0,0,.35);
  --maxw:      1120px;

  --font-head: "Plus Jakarta Sans","Sora",system-ui,sans-serif;
  --font-body: "Inter",system-ui,-apple-system,sans-serif;
}

*{ box-sizing:border-box; }
html,body{ margin:0; padding:0; }
body{
  font-family:var(--font-body);
  color:var(--text);
  background:
    radial-gradient(900px 600px at 78% 8%, rgba(21,32,58,.85), transparent 60%),
    radial-gradient(700px 600px at 92% 78%, rgba(20,40,42,.55), transparent 60%),
    var(--bg);
  background-attachment:fixed;
  min-height:100vh;
  line-height:1.55;
  font-size:15px;
}

/* Layout ---------------------------------------------------- */
.wrap{ max-width:var(--maxw); margin:0 auto; padding:0 20px; }
.section{ padding:28px 0; }
.grid{ display:grid; gap:16px; }
.grid-2{ grid-template-columns:repeat(2,1fr); }
.grid-3{ grid-template-columns:repeat(3,1fr); }
.grid-4{ grid-template-columns:repeat(4,1fr); }
.stack{ display:flex; flex-direction:column; gap:14px; }
.row{ display:flex; gap:12px; align-items:center; flex-wrap:wrap; }
.spacer{ flex:1; }

/* Typography ------------------------------------------------ */
h1,h2,h3{ font-family:var(--font-head); color:var(--text); margin:0 0 8px; line-height:1.15; letter-spacing:-.01em; }
h1{ font-size:42px; font-weight:800; }
h2{ font-size:26px; font-weight:700; }
h3{ font-size:18px; font-weight:700; }
p{ margin:0 0 10px; color:var(--text); }
.lead{ font-size:18px; color:var(--muted); }
.muted{ color:var(--muted); }
.gold{ color:var(--gold); }
a{ color:var(--gold); text-decoration:none; }

.section-label{
  font-family:var(--font-body); font-weight:700; font-size:12px;
  letter-spacing:.22em; text-transform:uppercase; color:var(--gold);
  display:inline-flex; align-items:center; gap:8px; margin-bottom:10px;
}
.section-label::before{ content:""; width:18px; height:2px; background:var(--gold); display:inline-block; }

/* Top bar --------------------------------------------------- */
.topbar{
  position:sticky; top:0; z-index:40;
  background:rgba(11,18,32,.82); backdrop-filter:blur(8px);
  border-bottom:1px solid var(--border);
}
.topbar .inner{ display:flex; align-items:center; gap:14px; padding:12px 20px; max-width:var(--maxw); margin:0 auto; }
.brand{ font-family:var(--font-head); font-weight:800; font-size:20px; color:var(--text); letter-spacing:-.02em; }
.brand .dot{ color:var(--gold); }

.role-switch{ display:flex; gap:6px; }
.role-switch a{
  font-size:13px; font-weight:600; color:var(--muted);
  padding:7px 12px; border:1px solid var(--border); border-radius:999px; background:transparent;
}
.role-switch a.active{ color:var(--text); border-color:var(--indigo); background:rgba(109,93,251,.12); }

.stage-select{
  background:var(--card); color:var(--text); border:1px solid var(--border);
  border-radius:999px; padding:7px 12px; font-size:13px;
}

/* Buttons --------------------------------------------------- */
.btn{
  display:inline-flex; align-items:center; gap:8px; cursor:pointer;
  font-family:var(--font-body); font-weight:700; font-size:14px;
  padding:11px 18px; border-radius:999px; border:1px solid transparent; text-decoration:none;
}
.btn-primary{ background:var(--indigo); color:#fff; }
.btn-primary:hover{ filter:brightness(1.08); }
.btn-gold{ background:var(--gold); color:#1a1500; }
.btn-gold:hover{ filter:brightness(1.05); }
.btn-ghost{ background:transparent; color:var(--text); border-color:var(--border); }
.btn-ghost:hover{ border-color:var(--indigo); }
.btn-lg{ padding:14px 24px; font-size:15px; }

/* Cards ----------------------------------------------------- */
.card{
  background:var(--card); border:1px solid var(--border);
  border-radius:var(--radius); padding:20px; box-shadow:var(--shadow);
}
.card-tight{ padding:14px 16px; }
.purpose{ color:var(--muted); font-size:14px; margin:-2px 0 14px; }

/* Pillar chips --------------------------------------------- */
.pillar-chip{
  display:inline-flex; align-items:center; justify-content:center;
  font-weight:700; font-size:13px; color:var(--text);
  background:var(--card-2); border:1px solid var(--border);
  border-radius:12px; padding:12px 14px; text-align:center; width:100%;
}
.chip-indigo{ border-color:var(--indigo); box-shadow:inset 0 0 0 1px rgba(109,93,251,.25); }
.chip-gold{ border-color:var(--gold); box-shadow:inset 0 0 0 1px rgba(245,197,24,.22); }
.chip-green{ border-color:var(--green); box-shadow:inset 0 0 0 1px rgba(46,158,91,.25); }
.chip-teal{ border-color:var(--teal); box-shadow:inset 0 0 0 1px rgba(20,184,166,.25); }
.chip-violet{ border-color:var(--violet); box-shadow:inset 0 0 0 1px rgba(139,124,240,.25); }

/* Numbered ring -------------------------------------------- */
.ring{
  flex:0 0 auto; width:44px; height:44px; border-radius:999px;
  display:flex; align-items:center; justify-content:center;
  font-family:var(--font-head); font-weight:800; font-size:15px; color:var(--text);
  border:2px solid var(--indigo); background:rgba(109,93,251,.12);
}
.ring.gold{ border-color:var(--gold); background:rgba(245,197,24,.12); }
.ring.green{ border-color:var(--green); background:rgba(46,158,91,.12); }
.ring.teal{ border-color:var(--teal); background:rgba(20,184,166,.12); }
.ring-item{ display:flex; gap:14px; align-items:flex-start; }

/* Skill chips ---------------------------------------------- */
.skill{
  display:inline-flex; align-items:center; gap:6px; font-size:12px; font-weight:600;
  padding:5px 10px; border-radius:999px; background:rgba(109,93,251,.12);
  border:1px solid var(--indigo); color:var(--text); margin:3px 4px 3px 0;
}
.skill.inferred{ background:transparent; border-style:dashed; border-color:var(--muted); color:var(--muted); }
.skill .conf{ font-size:10px; color:var(--muted); }

/* Donut ----------------------------------------------------- */
.donut-wrap{ display:flex; flex-direction:column; align-items:center; gap:6px; }
.donut{ width:120px; height:120px; }
.donut .track{ fill:none; stroke:var(--border); stroke-width:10; }
.donut .val{ fill:none; stroke-width:10; stroke-linecap:round; transform:rotate(-90deg); transform-origin:50% 50%; transition:stroke-dashoffset .6s ease; }
.donut .pct{ font-family:var(--font-head); font-weight:800; font-size:24px; fill:var(--text); }
.donut-label{ font-size:13px; color:var(--muted); }

/* KPI / data card ------------------------------------------ */
.kpi .num{ font-family:var(--font-head); font-weight:800; font-size:30px; color:var(--text); }
.kpi .lab{ font-size:13px; color:var(--muted); }
.kpi .tag{ font-size:11px; color:var(--gold); margin-top:6px; display:block; }

/* Status pills --------------------------------------------- */
.pill{ font-size:12px; font-weight:700; padding:3px 10px; border-radius:999px; }
.pill.ok{ background:rgba(46,158,91,.15); color:#7BE0A4; }
.pill.nudge{ background:rgba(224,168,46,.15); color:#F2CE7A; }
.pill.risk{ background:rgba(224,82,107,.15); color:#F2A0AF; }

/* Footer ---------------------------------------------------- */
.footer{ text-align:center; color:var(--muted); font-size:12px; padding:26px 20px 36px; border-top:1px solid var(--border); margin-top:30px; }
.disclaimer{ text-align:center; color:var(--muted); font-size:11px; padding:10px; opacity:.8; }

/* Hero ------------------------------------------------------ */
.hero{ padding:46px 0 26px; }
.hero h1{ max-width:14ch; }
.hero .lead{ max-width:46ch; }

/* Steps ----------------------------------------------------- */
.steps{ display:grid; grid-template-columns:repeat(3,1fr); gap:14px; }

/* Responsive ------------------------------------------------ */
@media (max-width:820px){
  h1{ font-size:32px; }
  .grid-2,.grid-3,.grid-4,.steps{ grid-template-columns:1fr; }
  .topbar .inner{ flex-wrap:wrap; }
  .hero{ padding:30px 0 18px; }
}

/* ===== Fasa 3 additions ===== */
/* Work Animal options */
.q .q-title{ font-weight:700; margin-bottom:10px; }
.opts{ display:grid; gap:8px; }
.opt{ display:block; cursor:pointer; position:relative; }
.opt input{ position:absolute; opacity:0; pointer-events:none; }
.opt .opt-box{ border:1px solid var(--border); border-radius:12px; padding:12px 14px; background:var(--card-2); font-size:14px; transition:.15s; }
.opt input:checked + .opt-box{ border-color:var(--indigo); background:rgba(109,93,251,.14); }
.opt:hover .opt-box{ border-color:var(--indigo); }

/* Tabs */
.tabs{ display:flex; gap:8px; margin-bottom:14px; flex-wrap:wrap; }
.tab{ padding:8px 14px; border:1px solid var(--border); border-radius:999px; cursor:pointer; font-size:13px; font-weight:600; color:var(--muted); }
.tab.active{ color:var(--text); border-color:var(--indigo); background:rgba(109,93,251,.12); }
.tabpanel{ display:none; }
.tabpanel.active{ display:block; }

/* Form fields */
textarea, .field{ width:100%; background:var(--card-2); border:1px solid var(--border); border-radius:12px; color:var(--text); padding:12px; font-family:inherit; font-size:14px; }
textarea{ min-height:120px; resize:vertical; }
.field{ border-radius:10px; padding:10px 12px; }
label.fl{ display:block; font-size:13px; color:var(--muted); margin:12px 0 4px; }
select.field{ appearance:none; }

/* Evidence list */
.ev{ padding:7px 0; border-bottom:1px solid var(--border); font-size:14px; color:var(--text); }
.ev:last-child{ border-bottom:none; }

/* Why drawer */
.drawer-backdrop{ position:fixed; inset:0; background:rgba(0,0,0,.55); display:none; z-index:50; }
.drawer-backdrop.open{ display:block; }
.drawer{ position:fixed; top:0; right:0; height:100%; width:380px; max-width:92vw; background:var(--card);
  border-left:1px solid var(--border); box-shadow:-12px 0 40px rgba(0,0,0,.45);
  transform:translateX(100%); transition:transform .3s ease; z-index:51; padding:22px; overflow:auto; }
.drawer.open{ transform:none; }
.subscore{ display:flex; justify-content:space-between; padding:9px 0; border-bottom:1px solid var(--border); font-size:14px; }

/* ===== Fasa 4: Compass path cards ===== */
.path-card{ cursor:pointer; transition:.15s; }
.path-card:hover{ border-color:var(--pc, var(--indigo)); }
.path-card.sel{ border-color:var(--pc, var(--indigo)); box-shadow:inset 0 0 0 1px var(--pc, var(--indigo)), var(--shadow); }

/* ===== Fasa 7: Guided tour ===== */
.tour-dim{ position:fixed; inset:0; background:rgba(3,6,14,.62); z-index:9000; pointer-events:none; }
.tour-target{ position:relative; z-index:9001; border-radius:14px;
  box-shadow:0 0 0 3px var(--gold), 0 0 0 10px rgba(245,197,24,.22); }
.tour-pop{ position:fixed; left:50%; bottom:24px; transform:translateX(-50%); z-index:9002;
  width:92%; max-width:460px; background:var(--card); border:1px solid var(--border);
  border-radius:14px; padding:16px 18px; box-shadow:var(--shadow); }
.tour-pop h4{ margin:2px 0 0; font-family:var(--font-head); font-size:17px; color:var(--text); }
.tour-pop .prog{ font-size:11px; letter-spacing:.12em; text-transform:uppercase; color:var(--gold); }
.tour-pop .row{ margin-top:12px; gap:8px; }
@media (max-width:820px){ .tour-pop{ bottom:12px; } }

/* ===== Fasa 8: polish ===== */
.pillars{ display:grid; grid-template-columns:repeat(5,1fr); gap:12px; }
.table-wrap{ overflow-x:auto; }
@media (max-width:820px){ .pillars{ grid-template-columns:repeat(2,1fr); } }
